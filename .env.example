# Public API base (backend). No trailing slash. Read on the server at runtime and injected for the browser.
# Local: http://localhost:5001/api  (match backend PORT; see Digital-Products-Selling--Backend/.env)
# Production: set to your real HTTPS API, e.g. https://api.yourdomain.com/api
PUBLIC_API_URL=http://localhost:5001/api

# Server-only (optional): preferred for SSR when it differs from the browser (e.g. internal Docker host).
# If PUBLIC_API_URL is still localhost in production but API_URL is a real https://… URL, the layout
# injects API_URL for the browser so login/cart (client) use the same backend as product SSR.
# Same shape as PUBLIC_API_URL, e.g. https://api.example.com/api
# BACKEND_URL is an alias for API_URL (either may be set).
# API_URL=
# BACKEND_URL=

# Base URL for product/upload images (e.g. http://localhost:5000/uploads).
# If unset, derived from API URL (removes /api).
# NEXT_PUBLIC_UPLOAD_BASE=http://localhost:5000/uploads

# Optional: use cookie name for auth token (if backend sets httpOnly cookie).
# If not set, token is read from localStorage key: auth_token
# NEXT_PUBLIC_AUTH_COOKIE_NAME=auth_token

# Public site URL (no trailing slash) — used for canonical URLs, sitemap, robots, and JSON-LD.
# Use the SAME host Google shows (www vs non-www), e.g. if results are https://www.parvesbd.com use that.
# Example: https://parvesbd.com
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: display name for titles and schema (defaults to "Parves BD").
# NEXT_PUBLIC_SITE_NAME=Parves BD

# Google Search Console HTML tag verification — paste the content value only (not the full meta tag).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Store currency label for Product structured data (default BDT).
# NEXT_PUBLIC_STORE_CURRENCY=BDT
